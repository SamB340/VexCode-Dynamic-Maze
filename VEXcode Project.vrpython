{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nimport math\nimport random\nfrom vexcode_vr import *\n\n# Brain should be defined by default\nbrain=Brain()\n\ndrivetrain = Drivetrain(\"drivetrain\", 0)\npen = Pen(\"pen\", 8)\npen.set_pen_width(THIN)\nleft_bumper = Bumper(\"leftBumper\", 2)\nright_bumper = Bumper(\"rightBumper\", 3)\nfront_eye = EyeSensor(\"frontEye\", 4)\ndown_eye = EyeSensor(\"downEye\", 5)\nfront_distance = Distance(\"frontdistance\", 6)\ndistance = front_distance\nmagnet = Electromagnet(\"magnet\", 7)\nlocation = Location(\"location\", 9)\n\n#endregion VEXcode Generated Robot Configuration\n\n\ndef getGridPosition(grid):\n    x = round(location.position(X, MM) / grid) * grid\n    y = round(location.position(Y, MM) / grid) * grid\n    return (x, y) # rounds locations in maze to avoid small changes not being recognised\n\n\ndef nextPosition(x,y,grid):\n\n    direction = round(location.position_angle(DEGREES) / 90) % 4\n\n    if direction == 0:\n        return(x,y+grid)\n    if direction == 1:\n        return(x+grid,y)\n    if direction == 2:\n        return(x,y-grid)\n    if direction == 3:\n        return(x-grid,y) # next place robot will move depending on where it is looking\n\n\ndef when_started1():\n    visited = set()\n    stack = []\n    count = 0\n    pen.move(DOWN)\n    gridSize = 250\n    outsideMaze = [(250, -1250), (0, 1000)]\n    mazeEnd = (0,750)\n    endFlag = False\n\n\n    startPosition = getGridPosition(gridSize)\n    \n    currentX, currentY = startPosition\n    visited.add((currentX, currentY)) # adds start of maze into stack\n\n    while True:\n        currentX, currentY = getGridPosition(gridSize)\n        nextX, nextY = nextPosition(currentX, currentY,gridSize)\n        \n        if (currentX,currentY) == mazeEnd and endFlag == False:\n            brain.print(\"Shortest Route: \" + str(stack))\n            endFlag = True\n        \n        elif not front_eye.detect(RED) and (nextX, nextY) not in visited and (nextX, nextY) not in outsideMaze:\n            stack.append((currentX, currentY))\n            drivetrain.drive_for(FORWARD, gridSize, MM)\n            visited.add(getGridPosition(gridSize))\n            count = 0 # moves robot forward if next space is available\n\n        elif count == 4:\n            if len(stack) > 0:\n                previousX, previousY = stack.pop()\n                \n                dx = previousX - currentX\n                dy = previousY - currentY\n                if dx > 100:   drivetrain.turn_to_heading(90, DEGREES)\n                elif dx < -100: drivetrain.turn_to_heading(270, DEGREES)\n                elif dy > 100:  drivetrain.turn_to_heading(0, DEGREES)\n                elif dy < -100: drivetrain.turn_to_heading(180, DEGREES)\n                \n                drivetrain.drive_for(FORWARD, gridSize, MM)\n                count = 0 # returns robot to previous location if at a dead end\n            else:\n                if getGridPosition(gridSize) == startPosition:\n                    drivetrain.stop()\n                    break\n\n        else:\n            drivetrain.turn_for(RIGHT, 90, DEGREES)\n            count = count + 1\n\n        wait(5, MSEC)\n\n\nvr_thread(when_started1())\n","textLanguage":"python","robotConfig":[],"slot":0,"platform":"PG","sdkVersion":"20240802.15.00.00","appVersion":"4.63.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"playground":"DynamicWallMaze","robotModel":"vr"}